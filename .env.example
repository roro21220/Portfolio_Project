# Copie ce fichier en ".env" et colle tes valeurs Supabase.
# IMPORTANT : utilise UNIQUEMENT la cle publishable / anon. JAMAIS la cle secrete (sb_secret_...).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
# (le code accepte aussi VITE_SUPABASE_PUBLISHABLE_KEY si tu preferes ce nom)
